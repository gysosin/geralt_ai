# Core
ENVIRONMENT=development
DEBUG=True
API_ENDPOINT=127.0.0.1:8000
AUTO_START_CELERY_WORKER=True
ALLOW_ANONYMOUS_AGENT_PLATFORM=True
SECRET_KEY=replace-with-a-local-development-secret

# CORS
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Databases and infrastructure
MONGO_URI=mongodb://127.0.0.1:27018
MONGO_DATABASE=geraltai
ELASTICSEARCH_URL=http://127.0.0.1:9209
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
MINIO_ENDPOINT=127.0.0.1:9003
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=False
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# AI providers
DEFAULT_AI_MODEL=gemini
DEFAULT_EMBEDDING_MODEL=gemini
DEFAULT_RERANKER=none
GEMINI_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
JINAAI_API_KEY=

# RAG
CHUNK_SIZE=1000
CHUNK_OVERLAP=128
RETRIEVAL_TOP_K=10
RERANK_TOP_N=10
VECTOR_WEIGHT=0.7
KEYWORD_WEIGHT=0.3
EMBEDDING_DIMENSION=1536

# Uploads
MAX_CONTENT_LENGTH=104857600
